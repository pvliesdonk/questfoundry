{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://questfoundry.liesdonk.nl/schemas/prose_notes.schema.json",
  "title": "Prose Notes",
  "description": "Specific guidance from Lore Weaver to Scene Smith on how to reflect new canon in prose: foreshadowing, callbacks, description updates, and beat adjustments. Producer: Lore Weaver. Consumers: Scene Smith, Style Lead.",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Canon topic or TU identifier"
    },
    "from": {
      "type": "string",
      "const": "Lore Weaver",
      "description": "Producer role (always Lore Weaver)"
    },
    "to": {
      "type": "string",
      "const": "Scene Smith",
      "description": "Primary consumer role (always Scene Smith)"
    },
    "canon_source": {
      "type": "string",
      "pattern": "^(TU-\\d{4}-\\d{2}-\\d{2}-[A-Z]{2}\\d{2}|Canon Pack .+)$",
      "description": "Canon Pack TU-ID or reference"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Creation date (YYYY-MM-DD)"
    },
    "sections_affected": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of section anchors or ranges affected by this guidance"
    },
    "foreshadowing_opportunities": {
      "type": "array",
      "description": "Hints to plant in prose that set up future reveals without spoiling",
      "items": {
        "type": "object",
        "properties": {
          "sections": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Section anchors or ranges"
          },
          "canon_context": {
            "type": "string",
            "description": "Spoiler-level truth being foreshadowed"
          },
          "prose_cue": {
            "type": "string",
            "description": "What to show/describe without revealing"
          },
          "timing": {
            "type": "string",
            "description": "When in section to place cue"
          },
          "restraint_note": {
            "type": "string",
            "description": "What NOT to say or imply"
          }
        },
        "required": ["sections", "canon_context", "prose_cue", "restraint_note"]
      }
    },
    "callback_moments": {
      "type": "array",
      "description": "References to prior events or details that reinforce continuity",
      "items": {
        "type": "object",
        "properties": {
          "sections": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Section anchors or ranges"
          },
          "prior_anchor": {
            "type": "string",
            "description": "Section where detail was established"
          },
          "canon_link": {
            "type": "string",
            "description": "What connects the moments"
          },
          "prose_cue": {
            "type": "string",
            "description": "How character/narrator references prior moment"
          },
          "emotional_weight": {
            "type": "string",
            "enum": ["nostalgic", "tense", "ironic", "relieved", "triumphant", "regretful"],
            "description": "Emotional tone of callback"
          }
        },
        "required": ["sections", "prior_anchor", "canon_link", "prose_cue", "emotional_weight"]
      }
    },
    "description_updates": {
      "type": "array",
      "description": "State changes that must be reflected in prose (physical, social, environmental)",
      "items": {
        "type": "object",
        "properties": {
          "sections": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Section anchors or ranges"
          },
          "entity_location": {
            "type": "string",
            "description": "What entity or location changed"
          },
          "before_state": {
            "type": "string",
            "description": "Prior description or assumption"
          },
          "after_state": {
            "type": "string",
            "description": "New canonical truth"
          },
          "prose_adjustment": {
            "type": "string",
            "description": "What to add, remove, or rewrite"
          },
          "visibility_note": {
            "type": "string",
            "description": "Who could notice this change in-world"
          }
        },
        "required": [
          "sections",
          "entity_location",
          "before_state",
          "after_state",
          "prose_adjustment"
        ]
      }
    },
    "beat_adjustments": {
      "type": "array",
      "description": "Emotional or pacing shifts required by canonical timeline or causality",
      "items": {
        "type": "object",
        "properties": {
          "sections": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Section anchors or ranges"
          },
          "canon_driver": {
            "type": "string",
            "description": "What canonical change drives this beat"
          },
          "current_beat": {
            "type": "string",
            "description": "Existing emotional arc or tone"
          },
          "adjusted_beat": {
            "type": "string",
            "description": "New emotional arc or tone"
          },
          "rationale": {
            "type": "string",
            "description": "Why canon requires this shift"
          }
        },
        "required": ["sections", "canon_driver", "current_beat", "adjusted_beat", "rationale"]
      }
    },
    "spoiler_boundaries": {
      "type": "array",
      "description": "What Scene Smith must NOT reveal in current sections",
      "items": {
        "type": "object",
        "properties": {
          "spoiler": {
            "type": "string",
            "description": "Canonical truth to keep hidden"
          },
          "safe_phrasing": {
            "type": "string",
            "description": "What can be said neutrally"
          },
          "unsafe_phrasing": {
            "type": "string",
            "description": "What would leak the spoiler"
          },
          "reveal_timing": {
            "type": "string",
            "description": "When spoiler becomes safe (act/chapter/anchor or 'never')"
          }
        },
        "required": ["spoiler", "safe_phrasing", "unsafe_phrasing", "reveal_timing"]
      }
    }
  },
  "required": [
    "title",
    "from",
    "to",
    "canon_source",
    "date",
    "sections_affected"
  ]
}
