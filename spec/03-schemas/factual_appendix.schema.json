{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://questfoundry.liesdonk.nl/schemas/factual_appendix.schema.json",
  "title": "Factual Appendix",
  "description": "Citations for corroborated factual claims in canon, or uncertainty level tracking for uncorroborated claims. Supports research posture transparency and downstream neutral phrasing. Producer: Lore Weaver (with Researcher input). Consumers: Researcher, Scene Smith, PN.",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Canon topic or TU identifier"
    },
    "canon_source": {
      "type": "string",
      "pattern": "^(TU-\\d{4}-\\d{2}-\\d{2}-[A-Z]{2}\\d{2}|Canon Pack .+)$",
      "description": "Canon Pack TU-ID or reference"
    },
    "lore_weaver": {
      "type": "string",
      "description": "Lore Weaver name or agent identifier"
    },
    "researcher": {
      "type": "string",
      "description": "Researcher name/agent or 'dormant'"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Creation date (YYYY-MM-DD)"
    },
    "overall_posture": {
      "type": "string",
      "enum": [
        "corroborated",
        "plausible",
        "disputed",
        "uncorroborated:low",
        "uncorroborated:medium",
        "uncorroborated:high"
      ],
      "description": "Overall research posture (highest-risk claim in appendix)"
    },
    "corroborated_claims": {
      "type": "array",
      "description": "Factual claims with verified sources and citations",
      "items": {
        "type": "object",
        "properties": {
          "claim": {
            "type": "string",
            "description": "Factual statement from canon"
          },
          "sources": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Citations: books, articles, datasets, expert interviews, etc."
          },
          "verification_method": {
            "type": "string",
            "enum": ["primary source", "expert review", "cross-reference"],
            "description": "How claim was corroborated"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium"],
            "description": "Confidence level"
          },
          "notes": {
            "type": "string",
            "description": "Caveats, limitations, or contextual details"
          }
        },
        "required": ["claim", "sources", "verification_method", "confidence"]
      }
    },
    "plausible_claims": {
      "type": "array",
      "description": "Reasonable extrapolations or accepted industry assumptions",
      "items": {
        "type": "object",
        "properties": {
          "claim": {
            "type": "string",
            "description": "Factual statement from canon"
          },
          "basis": {
            "type": "string",
            "description": "Why this is plausible: analogy | expert opinion | common practice"
          },
          "not_verified_by": {
            "type": "string",
            "description": "What would be needed for full corroboration"
          },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium"],
            "description": "Risk if unverified"
          },
          "notes": {
            "type": "string",
            "description": "Assumptions or context"
          }
        },
        "required": ["claim", "basis", "not_verified_by", "risk_level"]
      }
    },
    "disputed_claims": {
      "type": "array",
      "description": "Claims with conflicting sources or expert disagreement",
      "items": {
        "type": "object",
        "properties": {
          "claim": {
            "type": "string",
            "description": "Factual statement from canon"
          },
          "position_a": {
            "type": "string",
            "description": "One interpretation or source"
          },
          "position_b": {
            "type": "string",
            "description": "Conflicting interpretation or source"
          },
          "canon_choice": {
            "type": "string",
            "description": "Which position canon adopts, or if canon defers"
          },
          "rationale": {
            "type": "string",
            "description": "Why canon chose this position (narrative fit | best evidence | pragmatic)"
          },
          "risk_level": {
            "type": "string",
            "enum": ["medium", "high"],
            "description": "Risk if wrong"
          },
          "notes": {
            "type": "string",
            "description": "How to acknowledge uncertainty in player-safe text if needed"
          }
        },
        "required": [
          "claim",
          "position_a",
          "position_b",
          "canon_choice",
          "rationale",
          "risk_level"
        ]
      }
    },
    "uncorroborated_claims": {
      "type": "array",
      "description": "Claims not yet verified by Researcher (or Researcher dormant)",
      "items": {
        "type": "object",
        "properties": {
          "claim": {
            "type": "string",
            "description": "Factual statement from canon"
          },
          "uncertainty_level": {
            "type": "string",
            "enum": ["uncorroborated:low", "uncorroborated:medium", "uncorroborated:high"],
            "description": "Uncertainty level"
          },
          "why_uncorroborated": {
            "type": "string",
            "description": "Researcher dormant | time constraints | sources unavailable"
          },
          "neutral_phrasing": {
            "type": "string",
            "description": "How Scene Smith/PN should phrase without asserting as fact"
          },
          "revisit_trigger": {
            "type": "string",
            "description": "When to schedule Researcher pass (before Act II | before export | optional)"
          },
          "risk_if_wrong": {
            "type": "string",
            "enum": ["low", "medium", "high"],
            "description": "Narrative impact if claim is false"
          }
        },
        "required": [
          "claim",
          "uncertainty_level",
          "why_uncorroborated",
          "neutral_phrasing",
          "revisit_trigger",
          "risk_if_wrong"
        ]
      }
    },
    "research_gaps": {
      "type": "array",
      "description": "Areas where canon needs factual input but doesn't have it yet",
      "items": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "description": "What needs research"
          },
          "canon_impact": {
            "type": "string",
            "description": "Why this matters to the story"
          },
          "hook_filed": {
            "type": "string",
            "description": "Hook-id if filed for Researcher, or 'none'"
          },
          "workaround": {
            "type": "string",
            "description": "How canon proceeds without this info (defer | neutral phrasing | fictional substitute)"
          }
        },
        "required": ["topic", "canon_impact", "hook_filed", "workaround"]
      }
    }
  },
  "required": [
    "title",
    "canon_source",
    "lore_weaver",
    "researcher",
    "date",
    "overall_posture"
  ]
}
