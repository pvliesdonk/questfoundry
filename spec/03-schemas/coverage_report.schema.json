{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://questfoundry.liesdonk.nl/schemas/coverage_report.schema.json",
  "title": "Coverage Report",
  "description": "Documents what new terms are now covered by codex entries, remaining red-links (undefined terms), and hooks filed for gaps. Tracks codex completeness for a given TU or milestone. Producer: Codex Curator. Consumers: Lore Weaver, Scene Smith, Translator.",
  "type": "object",
  "properties": {
    "tu_or_milestone": {
      "type": "string",
      "description": "TU-ID or milestone name"
    },
    "codex_curator": {
      "type": "string",
      "description": "Codex Curator name or agent identifier"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Report date (YYYY-MM-DD)"
    },
    "scope": {
      "type": "string",
      "description": "Sections or chapters analyzed (e.g., 'Chapter 2 sections anchor010-anchor025')"
    },
    "new_entries_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of new codex entries created"
    },
    "red_links_remaining_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of undefined terms still present"
    },
    "coverage_percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Coverage percentage (optional metric)"
    },
    "new_terms_covered": {
      "type": "array",
      "description": "Terms now defined by codex entries in this TU",
      "items": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string",
            "description": "Term name or phrase"
          },
          "entry_id": {
            "type": "string",
            "description": "Codex entry file or anchor"
          },
          "category": {
            "type": "string",
            "enum": ["character", "location", "organization", "concept", "item", "procedure"],
            "description": "Entry category"
          },
          "status": {
            "type": "string",
            "enum": ["new entry", "updated entry"],
            "description": "Whether entry is new or updated"
          },
          "crosslinks_added": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of see-also links to other entries"
          },
          "source": {
            "type": "string",
            "description": "Canon Pack TU-ID or player-safe summary source"
          }
        },
        "required": ["term", "entry_id", "category", "status", "source"]
      }
    },
    "remaining_red_links": {
      "type": "array",
      "description": "Undefined terms still present in manuscript or codex entries",
      "items": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string",
            "description": "Undefined term or phrase"
          },
          "appears_in": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Section anchors or codex entries where term appears"
          },
          "frequency": {
            "type": "integer",
            "minimum": 1,
            "description": "Count of occurrences"
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Priority based on player comprehension impact"
          },
          "action": {
            "type": "string",
            "enum": ["create entry", "defer", "replace with defined term"],
            "description": "Recommended action"
          },
          "hook_filed": {
            "type": "string",
            "description": "Hook-id if requesting Lore summary, or 'none'"
          }
        },
        "required": ["term", "appears_in", "frequency", "priority", "action", "hook_filed"]
      }
    },
    "deferred_terms": {
      "type": "array",
      "description": "Terms intentionally not defined yet (with rationale)",
      "items": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string",
            "description": "Term name"
          },
          "reason": {
            "type": "string",
            "description": "Why deferred (spoiler | not yet relevant | planned for later | low player value)"
          },
          "deferred_until": {
            "type": "string",
            "description": "Act/chapter/milestone when term becomes safe to define"
          },
          "workaround": {
            "type": "string",
            "description": "How manuscript handles undefined term (context clues | synonym | omit)"
          },
          "hook_for_later": {
            "type": "string",
            "description": "Hook-id if filed for future expansion, or 'none'"
          }
        },
        "required": ["term", "reason", "deferred_until", "workaround", "hook_for_later"]
      }
    },
    "hooks_filed": {
      "type": "array",
      "description": "Requests filed during this coverage analysis",
      "items": {
        "type": "object",
        "properties": {
          "hook_id": {
            "type": "string",
            "pattern": "^HK-\\d{8}-\\d{2}$",
            "description": "Hook card ID"
          },
          "type": {
            "type": "string",
            "enum": [
              "lore-summary-needed",
              "research-needed",
              "taxonomy-clarification",
              "synonym-request",
              "defer-until-later"
            ],
            "description": "Hook type"
          },
          "term_topic": {
            "type": "string",
            "description": "What term or topic needs work"
          },
          "target_role": {
            "type": "string",
            "description": "Role to address hook (Lore Weaver | Researcher | Style Lead | Scene Smith)"
          },
          "urgency": {
            "type": "string",
            "enum": ["before next export", "before Act II", "before Act III", "optional"],
            "description": "Urgency level"
          }
        },
        "required": ["hook_id", "type", "term_topic", "target_role", "urgency"]
      }
    },
    "coverage_metrics": {
      "type": "object",
      "description": "Quantitative tracking of codex completeness (optional)",
      "properties": {
        "total_unique_terms": { "type": "integer", "minimum": 0 },
        "terms_with_entries": { "type": "integer", "minimum": 0 },
        "coverage_percentage": { "type": "number", "minimum": 0, "maximum": 100 },
        "total_crosslinks": { "type": "integer", "minimum": 0 },
        "broken_links": { "type": "integer", "minimum": 0 },
        "orphan_entries": { "type": "integer", "minimum": 0 },
        "coverage_change_since_last": { "type": "number" },
        "red_links_resolved": { "type": "integer", "minimum": 0 },
        "new_red_links_introduced": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "required": [
    "tu_or_milestone",
    "codex_curator",
    "date",
    "scope",
    "new_entries_count",
    "red_links_remaining_count",
    "new_terms_covered",
    "remaining_red_links"
  ]
}
