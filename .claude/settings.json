{
    "permissions": {
        "allow": [
            "Read",
            "Write",
            "Edit",
            "MultiEdit",
            "Glob",
            "Grep",
            "LS",
            "WebFetch",
            "WebSearch",
            "Bash(npm:*)",
            "Bash(git:*)",
            "Bash(ls:*)",
            "Bash(uv:*)",
            "Bash(echo:*)",
            "Bash(set:*)",
            "Bash(export:*)",
            "Bash(gh:*)",
            "Bash(timeout 600 uv run qf ask:*)",
            "Bash(rm:*)",
            "Bash(mkdir:*)",
            "Bash(sqlite3:*)",
            "Bash(python3:*)",
            "Bash(cat:*)",
            "Bash(find:*)",
            "Bash(grep:*)",
            "Bash(tee:*)",
            "Bash(timeout 900 uv run qf ask:*)",
            "Bash(jq:*)",
            "Bash(tail:*)"
        ],
        "deny": [],
        "ask": []
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/remind-domain-first.sh"
                    }
                ]
            }
        ]
    }
}
