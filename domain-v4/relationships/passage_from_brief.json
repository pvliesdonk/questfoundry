{
  "$schema": "../../meta/schemas/core/relationship.schema.json",
  "id": "passage_from_brief",
  "name": "Passage from Brief",
  "description": "Passages are derived from passage briefs. When a brief is edited, derived passages should be demoted to draft for review.",
  "from_type": "passage_brief",
  "to_type": "passage",
  "kind": "derived_from",
  "link_field": "brief_ref",
  "link_resolution": "by_field_match",
  "match_field": "brief_id",
  "impact_policy": {
    "on_parent_edit": "demote",
    "on_parent_delete": "orphan"
  }
}
