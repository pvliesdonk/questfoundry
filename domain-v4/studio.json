    "stores/manuscript.json",
    "stores/codex.json",
    "stores/audit.json",
    "stores/exports.json"
  ],

  "agents": [
    "agents/showrunner.json",
    "agents/gatekeeper.json",
    "agents/plotwright.json",
    "agents/scene_smith.json",
    "agents/researcher.json",
    "agents/book_binder.json",
    "agents/lore_weaver.json",
    "agents/codex_curator.json",
    "agents/style_lead.json",
    "agents/art_director.json",
    "agents/audio_director.json",
    "agents/player_narrator.json"
  ],

  "playbooks": [
    "playbooks/story_spark.json",
    "playbooks/scene_weave.json",
    "playbooks/hook_harvest.json",
    "playbooks/binding_run.json",
    "playbooks/lore_deepening.json",
