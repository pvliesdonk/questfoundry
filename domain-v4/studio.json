{
  "$schema": "../meta/schemas/core/studio.schema.json",
  "id": "questfoundry",
  "name": "QuestFoundry Interactive Fiction Studio",
  "version": "4.0.0",

  "description": "A multi-agent studio for creating interactive fiction with meaningful choices, diegetic gates, and player-safe surfaces. Decomposes the creative process into specialized roles coordinated through loops.",

  "entry_agents": {
    "authoring": "showrunner",
    "playtest": "player_narrator"
  },

  "constitution_ref": "governance/constitution.json",

  "stores": [
    "stores/workspace.json",
    "stores/canon.json",
    "stores/codex.json",
    "stores/audit.json",
    "stores/exports.json"
  ],

  "agents": [
    "agents/showrunner.json",
    "agents/gatekeeper.json",
    "agents/plotwright.json",
    "agents/scene_smith.json",
    "agents/researcher.json",
    "agents/book_binder.json",
    "agents/lore_weaver.json",
    "agents/codex_curator.json",
    "agents/style_lead.json",
    "agents/art_director.json"
  ],

  "playbooks": [
    "playbooks/story_spark.json",
    "playbooks/scene_weave.json",
    "playbooks/hook_harvest.json",
    "playbooks/binding_run.json",
    "playbooks/lore_deepening.json",
    "playbooks/art_planning.json"
  ],

  "artifact_types": [
    "artifact-types/section_brief.json",
    "artifact-types/section.json",
    "artifact-types/hook_card.json",
    "artifact-types/gatecheck_report.json",
    "artifact-types/research_memo.json",
    "artifact-types/view_log.json",
    "artifact-types/build_manifest.json",
    "artifact-types/canon_pack.json",
    "artifact-types/codex_entry.json",
    "artifact-types/style_addendum.json",
    "artifact-types/style_guide.json",
    "artifact-types/art_plan.json",
    "artifact-types/shotlist.json",
    "artifact-types/reference_sheet.json"
  ],

  "asset_types": [
    "asset-types/illustration.json"
  ],

  "tools": [
    "tools/consult_schema.json",
    "tools/validate_artifact.json",
    "tools/search_workspace.json",
    "tools/delegate.json",
    "tools/web_search.json",
    "tools/web_fetch.json",
    "tools/assemble_export.json",
    "tools/generate_image.json"
  ],

  "quality_criteria": [
    "governance/quality-criteria/integrity.json",
    "governance/quality-criteria/reachability.json",
    "governance/quality-criteria/nonlinearity.json",
    "governance/quality-criteria/gateways.json",
    "governance/quality-criteria/style.json",
    "governance/quality-criteria/determinism.json",
    "governance/quality-criteria/presentation.json",
    "governance/quality-criteria/accessibility.json"
  ],

  "knowledge_config": "knowledge/layers.json",

  "defaults": {
    "flow_control": {
      "max_inbox_size": 20,
      "max_active_delegations": 5,
      "backpressure_threshold": 0.8,
      "secretary_summarization_trigger": 10
    },
    "quality": {
      "max_rework_cycles": 3,
      "escalation_after_rework": true
    }
  },

  "metadata": {
    "wave": 4,
    "status": "visual_assets",
    "notes": "Wave 4: Added Art Director agent and generate_image tool (replaces Illustrator agent). Expanded Style Lead to own unified style (prose + visual + audio). New playbook: Art Planning. New artifact types: style_guide, art_plan, shotlist, reference_sheet (generalized from character_sheet to support characters, locations, and objects). New asset type: illustration. Simplified Art Plan from v2's 36 fields to ~15 fields. Philosophy: plan everything (cheap), generate selectively (expensive)."
  }
}
