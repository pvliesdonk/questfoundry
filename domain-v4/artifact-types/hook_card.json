{
  "$schema": "../../meta/schemas/core/artifact-type.schema.json",
  "id": "hook_card",
  "name": "Hook Card",
  "summary": "Captured idea for triage",
  "description": "A small, traceable follow-up capturing a new need or uncertainty without derailing current work. Hooks are classified, routed to the correct owner, and developed through loops. The player-safe summary is clean; spoilers live in hot_details only.",
  "category": "record",

  "fields": [
    {
      "name": "hook_id",
      "type": "string",
      "description": "Unique identifier (format: HK-YYYYMMDD-NN)",
      "required": true
    },
    {
      "name": "short_name",
      "type": "string",
      "description": "Brief name for the hook",
      "required": true
    },
    {
      "name": "raised_by",
      "type": "ref",
      "ref_target": "agent",
      "description": "Agent who raised this hook",
      "required": true
    },
    {
      "name": "tu_ref",
      "type": "string",
      "description": "Reference to originating TU Brief"
    },
    {
      "name": "slice",
      "type": "string",
      "description": "Scope indicator (e.g., 'Act I - Foreman Gate')"
    },
    {
      "name": "snapshot_context",
      "type": "string",
      "description": "Cold snapshot date for context (format: Cold @ YYYY-MM-DD)"
    },
    {
      "name": "classification",
      "type": "object",
      "description": "Hook type classification",
      "required": true,
      "properties": [
        {
          "name": "primary_type",
          "type": "string",
          "description": "Primary hook type",
          "enum": ["narrative", "scene", "factual", "taxonomy", "structure", "canon", "research", "style_pn", "translation", "art", "audio", "binder_nav", "accessibility"],
          "required": true
        },
        {
          "name": "secondary_type",
          "type": "string",
          "description": "Optional secondary type (cannot equal primary)",
          "enum": ["narrative", "scene", "factual", "taxonomy", "structure", "canon", "research", "style_pn", "translation", "art", "audio", "binder_nav", "accessibility"]
        },
        {
          "name": "bars_affected",
          "type": "array",
          "items_type": "string",
          "description": "Quality bars affected by this hook"
        },
        {
          "name": "blocking",
          "type": "boolean",
          "description": "Whether this hook blocks progress"
        },
        {
          "name": "blocking_reason",
          "type": "text",
          "description": "Explanation if blocking is true"
        }
      ]
    },
    {
      "name": "player_safe_summary",
      "type": "text",
      "description": "1-3 line description of the need. NO spoilers, codewords, internals, or mechanics.",
      "required": true,
      "max_length": 300
    },
    {
      "name": "hot_details",
      "type": "text",
      "description": "Internal details for routing (spoilers allowed). Hot-only, never surfaces to player views."
    },
    {
      "name": "proposed_next_step",
      "type": "object",
      "description": "Suggested loop and owner to resolve",
      "properties": [
        {
          "name": "loop",
          "type": "string",
          "description": "Loop to run",
          "enum": ["story_spark", "scene_weave", "hook_harvest", "lore_deepening", "codex_expansion", "style_tune_up", "art_touch_up", "audio_pass", "translation_pass", "binding_run", "narration_dry_run", "gatecheck", "post_mortem"]
        },
        {
          "name": "owner",
          "type": "ref",
          "ref_target": "agent",
          "description": "Responsible agent"
        },
        {
          "name": "accountable",
          "type": "ref",
          "ref_target": "agent",
          "description": "Accountable agent (usually Showrunner)"
        },
        {
          "name": "consult",
          "type": "array",
          "items_type": "string",
          "description": "Agents to consult"
        }
      ]
    },
    {
      "name": "acceptance_criteria",
      "type": "array",
      "description": "What must be true to close this hook",
      "items": {
        "name": "criterion",
        "type": "object",
        "properties": [
          {
            "name": "description",
            "type": "text",
            "description": "Criterion description"
          },
          {
            "name": "related_bar",
            "type": "string",
            "description": "Quality bar this criterion relates to"
          }
        ]
      }
    },
    {
      "name": "deferrals",
      "type": "object",
      "description": "If a track can wait safely",
      "properties": [
        {
          "name": "tags",
          "type": "array",
          "items_type": "string",
          "description": "Deferral tags (deferred:art, deferred:audio, deferred:translation, deferred:research)"
        },
        {
          "name": "fallback",
          "type": "text",
          "description": "What happens without deferred work"
        },
        {
          "name": "revisit",
          "type": "string",
          "description": "Loop or milestone to revisit"
        }
      ]
    },
    {
      "name": "locations",
      "type": "array",
      "items_type": "string",
      "description": "Player-safe anchor paths (/manuscript/...#anchor or /codex/...)"
    },
    {
      "name": "related_hooks",
      "type": "array",
      "items_type": "string",
      "description": "Related Hook Card IDs"
    },
    {
      "name": "lineage",
      "type": "object",
      "description": "Trace to source artifacts",
      "properties": [
        {
          "name": "canon_packs",
          "type": "array",
          "items_type": "string"
        },
        {
          "name": "research_memos",
          "type": "array",
          "items_type": "string"
        },
        {
          "name": "style_addendum",
          "type": "string"
        }
      ]
    },
    {
      "name": "resolution",
      "type": "object",
      "description": "Filled when hook is closed",
      "properties": [
        {
          "name": "decision",
          "type": "text",
          "description": "One sentence summary"
        },
        {
          "name": "work_performed",
          "type": "array",
          "items_type": "string",
          "description": "TU IDs that resolved this hook"
        },
        {
          "name": "view_impact",
          "type": "string",
          "enum": ["none", "rebind_needed"]
        },
        {
          "name": "gatekeeper_result",
          "type": "text",
          "description": "Bars green summary"
        },
        {
          "name": "resolved_by",
          "type": "ref",
          "ref_target": "agent"
        },
        {
          "name": "resolved_date",
          "type": "date"
        }
      ]
    }
  ],

  "lifecycle": {
    "states": [
      {
        "id": "proposed",
        "name": "Proposed",
        "description": "Hook has been raised, awaiting triage"
      },
      {
        "id": "accepted",
        "name": "Accepted",
        "description": "Hook accepted for work"
      },
      {
        "id": "in_progress",
        "name": "In Progress",
        "description": "Work is actively being done"
      },
      {
        "id": "resolved",
        "name": "Resolved",
        "description": "Work complete, hook closed"
      },
      {
        "id": "canonized",
        "name": "Canonized",
        "description": "Hook content has been merged to Cold",
        "terminal": true
      },
      {
        "id": "deferred",
        "name": "Deferred",
        "description": "Hook postponed with fallback"
      },
      {
        "id": "rejected",
        "name": "Rejected",
        "description": "Hook will not be pursued",
        "terminal": true
      }
    ],
    "initial_state": "proposed",
    "transitions": [
      { "from": "proposed", "to": "accepted" },
      { "from": "proposed", "to": "deferred" },
      { "from": "proposed", "to": "rejected" },
      { "from": "accepted", "to": "in_progress" },
      { "from": "accepted", "to": "deferred" },
      { "from": "in_progress", "to": "resolved" },
      { "from": "in_progress", "to": "deferred" },
      { "from": "resolved", "to": "canonized" },
      { "from": "resolved", "to": "in_progress" },
      { "from": "deferred", "to": "accepted" },
      { "from": "deferred", "to": "rejected" }
    ]
  },

  "validation": {
    "custom_rules": [
      {
        "id": "player_safe_summary_check",
        "description": "Player-safe summary must not contain spoilers, codewords, internal IDs, gate logic, or technique terms",
        "enforcement": "llm"
      },
      {
        "id": "blocking_requires_bars",
        "description": "If blocking is true, bars_affected must have at least one entry",
        "enforcement": "runtime"
      }
    ]
  },

  "default_store": "workspace"
}
