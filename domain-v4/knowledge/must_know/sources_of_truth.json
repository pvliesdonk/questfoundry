{
  "$schema": "../../../meta/schemas/knowledge/knowledge-entry.schema.json",
  "id": "sources_of_truth",
  "name": "Sources of Truth",
  "layer": "must_know",

  "summary": "Two SoTs exist: Hot (workspace) for discovery and Cold (canon) for curated truth. Work in Hot, merge to Cold after Gatekeeper passes. Views export from Cold snapshots only.",

  "keywords": ["hot", "cold", "workspace", "canon", "snapshot", "view", "merge", "stores"],

  "triggers": [
    "where to save work",
    "when to merge",
    "snapshot or view",
    "what is cold",
    "what is hot"
  ],

  "content": {
    "type": "structured",
    "format": "json",
    "schema_ref": "knowledge/structured-content.schema.json#/$defs/structured_entry",
    "data": {
      "definitions": [
        {
          "term": "Hot SoT (Workspace)",
          "meaning": "Discovery space for drafts, hooks, and work-in-progress. Mutable by all agents.",
          "distinguishing_features": [
            "All agents can read/write",
            "Spoilers allowed",
            "Canon work-in-progress lives here",
            "Plan-only assets (art/audio) staged here"
          ]
        },
        {
          "term": "Cold SoT (Canon)",
          "meaning": "Curated canon and player-safe surfaces. Immutable once committed.",
          "distinguishing_features": [
            "Cold semantics (exclusive production by Lore Weaver)",
            "No spoilers on player-facing content",
            "Only receives content after Gatekeeper passes all quality bars",
            "Ship-ready, not staging"
          ]
        },
        {
          "term": "Snapshot",
          "meaning": "Immutable tag of Cold at a point in time (e.g., `cold@2025-10-28`).",
          "distinguishing_features": [
            "Exports are cut from snapshots",
            "Views cite their source snapshot",
            "Provides versioning and rollback capability"
          ]
        },
        {
          "term": "View",
          "meaning": "Player-safe export bundle (MD/HTML/EPUB/PDF) built from a snapshot.",
          "distinguishing_features": [
            "Built from a snapshot via Binding Run",
            "Never ships from Hot",
            "Player-facing format"
          ]
        }
      ],
      "procedures": [
        {
          "goal": "Move content from draft to player-ready export",
          "steps": [
            "Work in Hot (workspace)",
            "Request Gatecheck (8 quality bars)",
            "Merge to Cold (on pass)",
            "Create Snapshot",
            "Build View from Snapshot"
          ],
          "postconditions": [
            "Content is in Cold store",
            "Snapshot is tagged",
            "View is ready for distribution"
          ]
        }
      ],
      "rules": [
        {
          "statement": "Never ship from Hot",
          "enforcement": "runtime",
          "severity": "critical",
          "reasoning": "Hot contains unvalidated work-in-progress that may have quality issues or spoilers."
        },
        {
          "statement": "Never bypass Gatekeeper",
          "enforcement": "runtime",
          "severity": "critical",
          "reasoning": "Quality bars exist to ensure player experience; bypassing breaks the guarantee."
        }
      ]
    }
  },

  "applicable_to": {
    "archetypes": ["orchestrator"],
    "agents": ["showrunner"]
  },

  "tags": ["architecture", "stores", "workflow"]
}
