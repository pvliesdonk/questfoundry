{
  "$schema": "https://questfoundry.liesdonk.nl/manifests/playbook_manifest.schema.json",
  "manifest_version": "2.0.0",
  "playbook_id": "lore_deepening",
  "display_name": "Lore Deepening",
  "compiled_at": "2025-11-15T20:00:12.808580+00:00",
  "source_files": [
    "/home/runner/work/questfoundry/questfoundry/spec/05-behavior/playbooks/lore_deepening.playbook.yaml",
    "/home/runner/work/questfoundry/questfoundry/spec/05-behavior/procedures/canonization_core.md",
    "/home/runner/work/questfoundry/questfoundry/spec/05-behavior/procedures/player_safe_summarization.md",
    "/home/runner/work/questfoundry/questfoundry/spec/05-behavior/procedures/continuity_check.md",
    "/home/runner/work/questfoundry/questfoundry/spec/05-behavior/procedures/artifact_validation.md",
    "/home/runner/work/questfoundry/questfoundry/spec/05-behavior/procedures/spoiler_hygiene.md",
    "/home/runner/work/questfoundry/questfoundry/spec/05-behavior/procedures/lore_translation.md",
    "/home/runner/work/questfoundry/questfoundry/spec/05-behavior/procedures/tu_lifecycle.md",
    "/home/runner/work/questfoundry/questfoundry/spec/05-behavior/snippets/validation_reminder.md"
  ],
  "category": "Discovery",
  "purpose": "Transform accepted hooks into coherent, contradiction-aware canon (backstories, timelines, metaphysics, causal links). Keep spoilers in canon notes; publish player-safe surfaces later via Codex Expansion.",
  "outcome": "Canonical entries ready to merge to Cold (after gatecheck), with clear lineage to hooks/TUs, plus notes for Plotwright/Scene Smith when structure or prose should react.",
  "steps": [
    {
      "step_id": "step_1",
      "name": "Open Lore Deepening TU",
      "description": "Open TU and broadcast to consulted roles",
      "assigned_roles": [
        "showrunner"
      ],
      "protocol_intent": "tu.open"
    },
    {
      "step_id": "step_2",
      "name": "Frame the Canon Question",
      "description": "For each theme/cluster: write a 1-3 line canon question",
      "assigned_roles": [
        "lore_weaver"
      ],
      "example": "What caused Kestrel's jaw scar, and who else was involved?"
    },
    {
      "step_id": "step_3",
      "name": "Draft Canon Answer",
      "description": "Provide precise, spoiler-level answer",
      "assigned_roles": [
        "lore_weaver"
      ]
    },
    {
      "step_id": "step_4",
      "name": "Check Contradictions & Coupling",
      "description": "Compare against Cold; identify clashes; propose reconciliations or mark deliberate mystery",
      "assigned_roles": [
        "lore_weaver"
      ]
    },
    {
      "step_id": "step_5",
      "name": "Factual Pass",
      "description": "Validate real-world claims; attach citations",
      "assigned_roles": [
        "researcher"
      ],
      "condition": "If Researcher active"
    },
    {
      "step_id": "step_6",
      "name": "Topology & Prose Notes",
      "description": "List consequences for gateways, loops, hubs; suggest hooks for Story Spark if needed",
      "assigned_roles": [
        "lore_weaver"
      ]
    },
    {
      "step_id": "step_7",
      "name": "Style Sweep",
      "description": "Annotate motif ties and tone consistency; no rewrite, only guidance",
      "assigned_roles": [
        "style_lead"
      ]
    },
    {
      "step_id": "step_8",
      "name": "Package Canon Entry",
      "description": "Package Canon Entry",
      "assigned_roles": [
        "lore_weaver"
      ]
    },
    {
      "step_id": "step_9",
      "name": "Pre-Gate Review",
      "description": "Early read for risks",
      "assigned_roles": [
        "gatekeeper"
      ],
      "protocol_intent": "gate.submit"
    },
    {
      "step_id": "step_10",
      "name": "Submit for Merge",
      "description": "After addressing pre-gate feedback, submit merge request",
      "assigned_roles": [
        "lore_weaver"
      ],
      "protocol_intent": "merge.request"
    },
    {
      "step_id": "step_11",
      "name": "Handoff",
      "description": "Send player-safe summaries to Codex Expansion; send topology/prose notes to Story Spark / Scene Smith",
      "assigned_roles": [
        "lore_weaver"
      ]
    }
  ],
  "raci": {
    "responsible": [
      "lore_weaver"
    ],
    "accountable": [
      "showrunner"
    ],
    "consulted": [
      "researcher",
      "plotwright",
      "scene_smith",
      "style_lead",
      "gatekeeper"
    ],
    "informed": [
      "codex_curator"
    ]
  },
  "quality_bars": [
    "integrity",
    "gateways"
  ],
  "artifacts": [
    "canon_pack.schema.json"
  ],
  "inputs": [
    "Accepted hooks (narrative/scene/factual/taxonomy) clustered by theme",
    "Current Cold canon/codex; relevant style guardrails",
    "Topology deltas from Story Spark (if any)",
    "Research memos or uncorroborated:<risk> flags"
  ],
  "deliverables": {
    "canon_pack": {
      "format": "Human text, spoiler-level",
      "per_entry": [
        "Title",
        "Canon Answer",
        "Timeline",
        "Entities/Factions",
        "Constraints",
        "Sensitivity",
        "Upstream hooks/TUs",
        "Downstream impacts",
        "Notes"
      ]
    },
    "prose_notes": {
      "recipient": "@adapter:scene_smith",
      "contents": "Foreshadow/callbacks/description updates"
    },
    "topology_notes": {
      "recipient": "@adapter:plotwright",
      "contents": "Gateway/loop implications"
    },
    "factual_appendix": {
      "contents": "Citations or uncorroborated:<risk> list"
    },
    "pre_gate_note": {
      "owner": "@adapter:gatekeeper",
      "contents": "Anticipated bar risks"
    }
  }
}