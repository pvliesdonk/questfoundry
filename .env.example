# QuestFoundry Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file!

# =============================================================================
# LLM Provider Configuration (choose one or more)
# =============================================================================

# OpenAI
# OPENAI_API_KEY=sk-...

# Google AI Studio (Gemini)
# GOOGLE_API_KEY=...

# Ollama (local models)
# OLLAMA_HOST=http://localhost:11434

# =============================================================================
# LangSmith Tracing (optional, for observability)
# =============================================================================

# Enable tracing (set to 'true' to enable)
# LANGSMITH_TRACING=true

# Your LangSmith API key
# LANGSMITH_API_KEY=lsv2_pt_...

# Project name in LangSmith (defaults to 'questfoundry')
# LANGSMITH_PROJECT=questfoundry

# =============================================================================
# Default Provider Selection
# =============================================================================

# Which provider to use by default: ollama, openai, google
# Can also be set in questfoundry.yaml
# QF_PROVIDER=ollama

# Default model (provider-specific)
# QF_MODEL=qwen3:8b
